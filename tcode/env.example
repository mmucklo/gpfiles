# TSLA Alpha Engine — environment variable template
# Copy to /home/builder/.tsla-alpha.env and fill in your values.
# NEVER commit the actual .tsla-alpha.env — it contains live credentials.

# ── IBKR (order execution only — NOT used for options chain data) ──────────────
export EXECUTION_MODE=IBKR_PAPER        # IBKR_PAPER | IBKR_LIVE | SIMULATION
export IBKR_HOST=127.0.0.1
export IBKR_PORT=4002                   # IB Gateway paper (TWS paper = 7497)
export IBKR_CLIENT_ID=1

# ── Tradier (options chain data source) ───────────────────────────────────────
# Get your token at: https://developer.tradier.com/
# Free real-time options data is included with a funded Tradier brokerage account.
export TRADIER_API_TOKEN=              # your token here — NEVER commit this value
export TRADIER_BASE_URL=https://api.tradier.com/v1
# Sandbox for testing (no real data, but safe for development):
# export TRADIER_BASE_URL=https://sandbox.tradier.com/v1

# ── Options chain source priority ─────────────────────────────────────────────
# "tradier" → Tradier only (fail loud if token missing or unavailable)
# "auto"    → Tradier → yfinance → IBKR cascade (default)
# "yfinance"→ yfinance only
# "ibkr"    → IBKR only (requires OPRA market data subscription)
export OPTIONS_CHAIN_SOURCE=tradier

# ── Position sizing ────────────────────────────────────────────────────────────
export NOTIONAL_ACCOUNT_SIZE=25000
export MAX_PENDING_ORDERS=2

# ── Liquidity floors (Phase 14) ────────────────────────────────────────────────
export MIN_OPTION_VOLUME_TODAY=50       # require >= 50 contracts traded today
export MIN_OPTION_OPEN_INTEREST=500     # require OI >= 500
export MAX_BID_ASK_PCT=0.15            # reject if (ask-bid)/mid > 15%
export MIN_ABSOLUTE_BID=0.10           # reject any contract with bid < $0.10
